{
  "name": "sass-js",
  "description": "Include Bootstrap's source Sass and compiled JavaScript bundle via npm.",
  "version": "0.0.0",
  "private": true,
  "repository": "twbs/examples",
  "license": "MIT",
  "stackblitz": {
    "startCommand": "npm start"
  },
  "scripts": {
    "build": "npm run css-prod && eleventy",
    "build:11ty": "eleventy",
    "serve": "eleventy --serve",
    "dev": "npm run css && npm-run-all --parallel watch serve",
    "css-compile": "sass --style compressed --source-map --embed-sources --no-error-css --load-path=node_modules scss/:css/",
    "css-compile-prod": "sass --style compressed --no-source-map --no-error-css --load-path=node_modules scss/:css/",
    "css-lint": "stylelint scss/",
    "css-prefix": "postcss --replace css/styles.css --use autoprefixer --map",
    "css-prefix-prod": "postcss --replace css/styles.css --use autoprefixer --no-map",
    "css": "npm-run-all css-compile css-prefix",
    "css-prod": "rm -f css/styles.css.map && npm-run-all css-compile-prod css-prefix-prod",
    "server": "sirv --dev --no-clear --port 3000",
    "start": "npm-run-all --parallel watch server",
    "watch": "nodemon -e scss -x \"npm run css\"",
    "test": "npm-run-all css-lint css"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.0"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@tinacms/cli": "^2.5.3",
    "autoprefixer": "^10.4.14",
    "js-yaml": "^5.2.1",
    "nodemon": "^3.0.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.27",
    "postcss-cli": "^10.1.0",
    "sass": "^1.64.1",
    "sirv-cli": "^2.0.2",
    "stylelint": "^15.10.2",
    "stylelint-config-twbs-bootstrap": "^11.0.1",
    "tinacms": "^3.10.0"
  }
}
