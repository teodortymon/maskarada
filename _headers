# Cloudflare Pages headers (passthrough-copied into _site/ by eleventy.config.js).
#
# CSP allowlist is built from the origins the templates actually load:
#   script:  kicket.com (header_t ticket widget), www.youtube.com (lite-yt-embed
#            loads iframe_api when js-api is enabled); inline scripts exist
#            throughout, hence 'unsafe-inline'.
#   style:   fonts.googleapis.com (Montserrat, header_t); inline styles exist.
#   font:    fonts.gstatic.com (served by the Google Fonts CSS).
#   img:     i.ytimg.com (lite-youtube poster thumbnails),
#            res.cloudinary.com (w/dziewczynki gallery), data: URIs.
#   frame:   www.youtube-nocookie.com (lite-yt-embed player iframe),
#            www.youtube.com (iframe_api players), www.google.com (maps embeds
#            on t/index, t/kontakt, w/kontakt), kicket.com (ticket widget).
#   connect: kicket.com (widget XHR).
#   form:    maps.google.com ("wyznacz trasę" directions form on t/kontakt).

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://kicket.com https://www.youtube.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://i.ytimg.com https://res.cloudinary.com; frame-src https://www.youtube-nocookie.com https://www.youtube.com https://www.google.com https://kicket.com; connect-src 'self' https://kicket.com; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self' https://maps.google.com http://maps.google.com

# Caching.
# Only t-section's lay/style.css reference goes through bust_file_cache
# versioning; css/styles.css, lay/style.css (root + w pages), t/lay images and
# t/js vendored libs are all fetched UNVERSIONED and do get edited in place —
# so they get a day, not a year.

# Compiled Bootstrap CSS — unversioned, actively edited during the v2 redesign.
/css/*
  Cache-Control: public, max-age=86400

# Shared legacy chrome — lay/style.css is loaded without a version query by the
# root index and w pages.
/lay/*
  Cache-Control: public, max-age=86400

# Theatre-section images (posters replaced/re-optimized in place, unversioned).
/t/lay/*
  Cache-Control: public, max-age=86400

# Vendored lite-youtube JS/CSS — unversioned pair; a year of staleness would
# outlive any library bump.
/t/js/*
  Cache-Control: public, max-age=86400

# Frozen legacy w-section assets: safe to cache hard.
/w/lay/*
  Cache-Control: public, max-age=31536000, immutable

/w/js/*
  Cache-Control: public, max-age=31536000, immutable

# Costume gallery (~1000 images, new costumes get new filenames; a stale cached
# copy after an in-place recompress is visually identical, just larger).
/w/kostiumy/*
  Cache-Control: public, max-age=31536000, immutable
